TELEGRAM_TOKEN=123456789:ABCdefGhIJKlmNOpqRSTuvWXyz
TELEGRAM_CHAT_ID=987654321

# Kaç puanlık fark bildirim göndersin? (varsayılan: 10)
THRESHOLD=10

# Kontrol aralığı (saniye) - ban önlemi için random aralıkta
POLL_INTERVAL_MIN=25
POLL_INTERVAL_MAX=40

# Aynı maç için aynı yönde tekrar bildirim süresi (saat)
ALERT_COOLDOWN_HOURS=2

# Veritabanı dosyası
DB_PATH=basketball.db

# Log seviyesi (DEBUG/INFO/WARNING)
LOG_LEVEL=INFO

# Opera browser CDP adresi (Opera'yı bu portla başlatmalısın)
OPERA_CDP_URL=http://127.0.0.1:9222

# AIScore basketbol sayfası
AISCORE_URL=https://www.aiscore.com/basketball

# Her döngüde en fazla kaç maç detayına girilsin
MAX_MATCHES_PER_CYCLE=40

# Sayfa timeout (ms)
PAGE_TIMEOUT_MS=30000
