TELEGRAM_TOKEN=123456789:ABCdefGhIJKlmNOpqRSTuvWXyz
TELEGRAM_CHAT_ID=987654321

# How many points difference should trigger a notification? (default: 10)
THRESHOLD=10

# Check interval (seconds) - randomized to prevent bans
POLL_INTERVAL_MIN=25
POLL_INTERVAL_MAX=40

# Re-alert cooldown for the same match and direction (minutes)
ALERT_COOLDOWN_MINUTES=15

# Database file
DB_PATH=basketball.db

# Log level (DEBUG/INFO/WARNING)
LOG_LEVEL=INFO

# Browser mode:
#   "opera"    → Uses Opera VPN on your local machine (when ISP blocks access)
#   "headless" → Runs headless Chrome on server (when VPN is not needed)
BROWSER_MODE=headless

# --- Opera mode settings (only required when BROWSER_MODE=opera) ---
# OPERA_CDP_URL=http://127.0.0.1:9222
# OPERA_CDP_PORT=9222
# OPERA_BINARY=

# AIScore basketball page
AISCORE_URL=https://www.aiscore.com/basketball

# Max matches to scan per cycle
MAX_MATCHES_PER_CYCLE=80

# Page timeout (ms)
PAGE_TIMEOUT_MS=30000
